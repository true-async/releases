{
  "php_version": "8.6",
  "php_is_latest": true,
  "php_src": {
    "repo": "true-async/php-src",
    "branch": "php-8.6.0-trueasync-0.8.1"
  },
  "extensions": {
    "async": {
      "repo": "true-async/php-async",
      "branch": "v0.8.1",
      "path": "ext/async"
    },
    "server": {
      "repo": "true-async/server",
      "branch": "v0.11.2"
    },
    "xdebug": {
      "repo": "true-async/xdebug",
      "branch": "php-8.6.0-trueasync-0.7.0",
      "path": "ext/xdebug"
    },
    "phpredis": {
      "repo": "true-async/phpredis",
      "branch": "v0.7.2"
    },
    "clickhouse": {
      "repo": "true-async/php-clickhouse",
      "branch": "v0.1.5"
    }
  },
  "frankenphp": {
    "repo": "true-async/frankenphp",
    "branch": "trueasync-0.7.0"
  },
  "requirements": {
    "libuv": "1.52.1",
    "openssl": "3.5.0",
    "nghttp2": "1.59.0",
    "nghttp3": "1.15.0",
    "ngtcp2": "1.22.1",
    "curl": "8.12.1"
  },
  "configure": {
    "common": [
      "--enable-zts",
      "--enable-async",
      "--enable-phpdbg",
      "--enable-bcmath",
      "--enable-calendar",
      "--enable-exif",
      "--enable-ftp",
      "--enable-intl",
      "--enable-mbstring",
      "--enable-pdo",
      "--enable-shmop",
      "--enable-soap",
      "--enable-sockets",
      "--with-bz2",
      "--with-curl",
      "--with-gettext",
      "--with-gmp",
      "--with-mysqli=mysqlnd",
      "--with-openssl",
      "--with-pdo-mysql=mysqlnd",
      "--with-pdo-pgsql",
      "--with-pdo-sqlite",
      "--with-pgsql",
      "--with-sqlite3",
      "--with-xsl",
      "--with-zlib"
    ],
    "linux": [
      "--enable-gd",
      "--with-jpeg",
      "--with-webp",
      "--with-freetype",
      "--with-zip",
      "--with-sodium",
      "--with-readline",
      "--with-tidy",
      "--with-ldap"
    ],
    "windows": [
      "--enable-gd=shared",
      "--with-jpeg",
      "--with-webp",
      "--with-freetype",
      "--enable-debug-pack"
    ],
    "android": [
      "--enable-embed=static",
      "--disable-phpdbg",
      "--disable-cli",
      "--disable-cgi",
      "--without-readline",
      "--without-ldap",
      "--without-tidy",
      "--without-pgsql",
      "--without-pdo-pgsql",
      "--without-gd",
      "--without-sodium",
      "--without-gmp",
      "--without-xsl",
      "--without-bz2",
      "--without-gettext",
      "--disable-exif",
      "--disable-intl",
      "--disable-soap",
      "--disable-calendar",
      "--disable-ftp",
      "--disable-shmop",
      "--with-pdo-sqlite",
      "--with-sqlite3",
      "--with-openssl",
      "--with-curl",
      "--with-zlib",
      "--without-iconv",
      "--disable-mbregex",
      "--disable-opcache",
      "--disable-zend-signals"
    ]
  },
  "android": {
    "ndk_version": "27.0.12077973",
    "api_level": "29",
    "abis": ["arm64-v8a", "x86_64"]
  }
}