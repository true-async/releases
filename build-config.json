{
  "php_version": "8.6",
  "php_is_latest": true,
  "php_src": {
    "repo": "true-async/php-src",
    "branch": "php-8.6.0-trueasync-0.7.0-alpha.13"
  },
  "extensions": {
    "async": {
      "repo": "true-async/php-async",
      "branch": "v0.7.0-alpha.13",
      "path": "ext/async"
    },
    "server": {
      "repo": "true-async/server",
      "branch": "v0.5.3"
    },
    "xdebug": {
      "repo": "true-async/xdebug",
      "branch": "php-8.6.0-trueasync-0.6.7",
      "path": "ext/xdebug"
    },
    "phpredis": {
      "repo": "true-async/phpredis",
      "branch": "v0.7.0-alpha.10"
    }
  },
  "frankenphp": {
    "repo": "true-async/frankenphp",
    "branch": "trueasync-0.6.7"
  },
  "requirements": {
    "libuv": "1.52.1",
    "openssl": "3.5.0",
    "nghttp2": "1.59.0",
    "nghttp3": "1.15.0",
    "ngtcp2": "1.22.1",
    "curl": "8.12.1"
  },
  "configure": {
    "common": [
      "--enable-zts",
      "--enable-async",
      "--enable-phpdbg",
      "--enable-bcmath",
      "--enable-calendar",
      "--enable-exif",
      "--enable-ftp",
      "--enable-intl",
      "--enable-mbstring",
      "--enable-pdo",
      "--enable-shmop",
      "--enable-soap",
      "--enable-sockets",
      "--with-bz2",
      "--with-curl",
      "--with-gettext",
      "--with-gmp",
      "--with-mysqli=mysqlnd",
      "--with-openssl",
      "--with-pdo-mysql=mysqlnd",
      "--with-pdo-pgsql",
      "--with-pdo-sqlite",
      "--with-pgsql",
      "--with-sqlite3",
      "--with-xsl",
      "--with-zlib"
    ],
    "linux": [
      "--enable-gd",
      "--with-jpeg",
      "--with-webp",
      "--with-freetype",
      "--with-zip",
      "--with-sodium",
      "--with-readline",
      "--with-tidy",
      "--with-ldap"
    ],
    "windows": [
      "--enable-gd=shared",
      "--with-jpeg",
      "--with-webp",
      "--with-freetype",
      "--enable-debug-pack"
    ]
  }
}
